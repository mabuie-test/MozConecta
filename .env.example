APP_NAME=MozConecta
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_KEY=base64:change-this
APP_TIMEZONE=Africa/Maputo

DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mozconecta
DB_USERNAME=root
DB_PASSWORD=

LOG_CHANNEL=single
LOG_LEVEL=debug

SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=Lax
AUTH_MAX_ATTEMPTS=5
AUTH_LOCK_MINUTES=15

DEBITO_BASE_URL=https://my.debito.co.mz
DEBITO_TOKEN=
DEBITO_EMAIL=
DEBITO_PASSWORD=
DEBITO_WALLET_ID_MPESA=
DEBITO_WALLET_ID_EMOLA=
DEBITO_CALLBACK_URL=
DEBITO_TIMEOUT=30
DEBITO_RETRY_COUNT=3
DEBITO_STATUS_POLLING_ENABLED=true
DEBITO_STATUS_POLLING_INTERVAL=60

PAYMENT_DEFAULT_PROVIDER=debito_mpesa

WHATSAPP_PROVIDER_DEFAULT=generic_api
WHATSAPP_API_BASE_URL=
WHATSAPP_API_KEY=
WHATSAPP_WEBHOOK_SECRET=change-me
WHATSAPP_SYNC_ENABLED=true
WHATSAPP_SYNC_INTERVAL=120

AI_DEFAULT_PROVIDER=openrouter
OPENROUTER_API_KEY=
GEMINI_API_KEY=

AI_TIMEOUT=25
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-1.5-flash

CSRF_ENABLED=true
WHATSAPP_VALIDATE_SIGNATURE=false
RATE_LIMIT_ENABLED=true
