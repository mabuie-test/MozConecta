{
  "name": "mozconecta/saas",
  "description": "MozConecta SaaS foundation (Phase 1)",
  "type": "project",
  "require": {
    "php": ">=8.2",
    "ext-pdo": "*"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    },
    "files": [
      "app/Support/helpers.php"
    ]
  },
  "scripts": {
    "serve": "php -S localhost:8080 -t public",
    "test": "bash tests/smoke.sh"
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  }
}
